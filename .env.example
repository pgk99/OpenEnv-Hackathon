# Environment Variables for Aviation Agent - Hackathon Submission

# =============================================================================
# LLM API Configuration (Required for inference.py)
# =============================================================================

# Option 1: OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
MODEL_NAME=gpt-4o-mini
API_BASE_URL=https://api.openai.com/v1

# Option 2: Hugging Face Inference API (Alternative)
# HF_TOKEN=hf_your-huggingface-token-here
# MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
# API_BASE_URL=https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.2/v1

# Option 3: Other OpenAI-compatible APIs
# HF_TOKEN=your-api-key-here
# MODEL_NAME=your-model-name
# API_BASE_URL=https://your-api-endpoint/v1

# =============================================================================
# Environment Server Configuration (Optional)
# =============================================================================

# URL of the Aviation Agent environment server
# Default: http://localhost:8000
AVIATION_ENV_URL=http://localhost:8000

# For deployed HF Space, use:
# AVIATION_ENV_URL=https://your-username-aviation-agent.hf.space

# =============================================================================
# Usage Instructions
# =============================================================================

# 1. Copy this file to .env:
#    cp .env.example .env

# 2. Fill in your API credentials

# 3. Source the file (Linux/Mac):
#    source .env
#    Or export manually:
#    export OPENAI_API_KEY=your-key-here

# 4. On Windows (PowerShell):
#    Get-Content .env | ForEach-Object {
#        if ($_ -match '^([^=]+)=(.*)$') {
#            [Environment]::SetEnvironmentVariable($matches[1], $matches[2])
#        }
#    }

# 5. Run inference:
#    python inference.py

# =============================================================================
# Model Recommendations
# =============================================================================

# For best results (most accurate):
# - gpt-4o (expensive but very accurate)
# - gpt-4o-mini (good balance of cost/performance)

# For budget-friendly:
# - gpt-3.5-turbo (cheaper, less accurate on hard tasks)

# For Hugging Face (free tier):
# - mistralai/Mistral-7B-Instruct-v0.2
# - meta-llama/Llama-2-7b-chat-hf (requires approval)

# =============================================================================
# Notes
# =============================================================================

# - HF_TOKEN and OPENAI_API_KEY are interchangeable in the inference script
# - The script uses OpenAI client library for all LLM calls
# - API_BASE_URL allows using any OpenAI-compatible API
# - Hugging Face Inference API is OpenAI-compatible
